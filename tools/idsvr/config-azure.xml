<config xmlns="http://tail-f.com/ns/config/1.0">
  <facilities xmlns="https://curity.se/ns/conf/base">
    <data-sources>
      <data-source>
        <id>default-datasource</id>
        <jdbc xmlns="https://curity.se/ns/ext-conf/jdbc">
          <connection-string>jdbc:sqlserver://#{SQL_SERVER_NAME}.database.windows.net:1433;database=#{SQL_DATABASE_NAME};encrypt=true;trustServerCertificate=false;hostNameInCertificate=*.database.windows.net;loginTimeout=30;sendStringParametersAsUnicode=false;</connection-string>
          <standard-credentials-mode>
          </standard-credentials-mode>
          <driver>com.microsoft.sqlserver.jdbc.SQLServerDriver</driver>
          <password>#{SQL_ADMIN_PASSWORD}</password>
          <username>#{SQL_ADMIN_USERNAME}@#{SQL_SERVER_NAME}</username>
        </jdbc>
      </data-source>
    </data-sources>
  </facilities>
</config>
