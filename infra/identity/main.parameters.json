{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "location": {
      "value": "${AZURE_LOCATION}"
    },
    "uniquePrefix": {
      "value": "${UNIQUE_PREFIX}"
    },
    "storageAccountName": {
      "value": "${STORAGE_ACCOUNT_NAME}"
    },
    "containerAppsEnvironmentId": {
      "value": "${CONTAINER_APPS_ENVIRONMENT_ID}"
    },
    "externalDomainName": {
      "value": "${EXTERNAL_DOMAIN_NAME}"
    },
    "containerRegistryName": {
      "value": "${CONTAINER_REGISTRY_NAME}"
    },
    "identityId": {
      "value": "${DEPLOYMENT_IDENTITY_ID}"
    },
    "gatewayExternalImageName": {
      "value": "${GATEWAY_EXTERNAL_IMAGE_NAME}"
    },
    "gatewayInternalImageName": {
      "value": "${GATEWAY_INTERNAL_IMAGE_NAME}"
    },
    "idsvrImageName": {
      "value": "${IDSVR_IMAGE_NAME}"
    },
    "sqlAdminUsername": {
      "value": "${SQL_ADMIN_USERNAME=sqladmin}"
    },
    "sqlAdminPassword": {
      "value": "${SQL_ADMIN_PASSWORD}"
    },
    "dbinitImageName": {
      "value": "${DBINIT_IMAGE_NAME}"
    },
    "adminPassword": {
      "value": "${ADMIN_PASSWORD}"
    },
    "licenseKey": {
      "value": "${LICENSE_KEY}"
    },
    "entraClientId": {
      "value": "${ENTRA_CLIENT_ID}"
    },
    "entraClientSecret": {
      "value": "${ENTRA_CLIENT_SECRET}"
    },
    "entraOidcMetadataUrl": {
      "value": "${ENTRA_OIDC_METADATA_URL}"
    },
    "gatewayTokenExchangeClientSecret": {
      "value": "${GATEWAY_TOKEN_EXCHANGE_SECRET}"
    },
    "agentTokenExchangeClientSecret": {
      "value": "${AGENT_TOKEN_EXCHANGE_SECRET}"
    }
  }
}
