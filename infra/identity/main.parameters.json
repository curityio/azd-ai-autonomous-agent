{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "location": {
      "value": "${AZURE_LOCATION}"
    },
    "uniquePrefix": {
      "value": "${UNIQUE_PREFIX}"
    },
    "storageAccountName": {
      "value": "${STORAGE_ACCOUNT_NAME}"
    },
    "containerAppsEnvironmentId": {
      "value": "${CONTAINER_APPS_ENVIRONMENT_ID}"
    },
    "externalDomainName": {
      "value": "${EXTERNAL_DOMAIN_NAME}"
    },
    "containerRegistryName": {
      "value": "${CONTAINER_REGISTRY_NAME}"
    },
    "identityId": {
      "value": "${DEPLOYMENT_IDENTITY_ID}"
    },
    "gatewayExternalImageName": {
      "value": "${GATEWAY_EXTERNAL_IMAGE_NAME}"
    },
    "gatewayInternalImageName": {
      "value": "${GATEWAY_INTERNAL_IMAGE_NAME}"
    },
    "idsvrImageName": {
      "value": "${IDSVR_IMAGE_NAME}"
    },
    "sqlAdminUsername": {
      "value": "${SQL_ADMIN_USERNAME=sqladmin}"
    },
    "dbinitImageName": {
      "value": "${DBINIT_IMAGE_NAME}"
    },
    "entraClientId": {
      "value": "${ENTRA_CLIENT_ID}"
    },
    "entraOidcMetadataUrl": {
      "value": "${ENTRA_OIDC_METADATA_URL}"
    },
    "sqlAdminPassword": {
      "reference": {
        "keyVault": {
          "id": "/subscriptions/${AZURE_SUBSCRIPTION_ID}/resourceGroups/${AZURE_RESOURCE_GROUP}/providers/Microsoft.KeyVault/vaults/${KEY_VAULT_NAME}"
        },
        "secretName": "SQL-ADMIN-PASSWORD"
      }
    },
    "adminPassword": {
      "reference": {
        "keyVault": {
          "id": "/subscriptions/${AZURE_SUBSCRIPTION_ID}/resourceGroups/${AZURE_RESOURCE_GROUP}/providers/Microsoft.KeyVault/vaults/${KEY_VAULT_NAME}"
        },
        "secretName": "ADMIN-PASSWORD"
      }
    },
    "licenseKey": {
      "reference": {
        "keyVault": {
          "id": "/subscriptions/${AZURE_SUBSCRIPTION_ID}/resourceGroups/${AZURE_RESOURCE_GROUP}/providers/Microsoft.KeyVault/vaults/${KEY_VAULT_NAME}"
        },
        "secretName": "LICENSE-KEY"
      }
    },
    "gatewayTokenExchangeClientSecret": {
      "reference": {
        "keyVault": {
          "id": "/subscriptions/${AZURE_SUBSCRIPTION_ID}/resourceGroups/${AZURE_RESOURCE_GROUP}/providers/Microsoft.KeyVault/vaults/${KEY_VAULT_NAME}"
        },
        "secretName": "GATEWAY-TOKEN-EXCHANGE-SECRET"
      }
    },
    "agentTokenExchangeClientSecret": {
      "reference": {
        "keyVault": {
          "id": "/subscriptions/${AZURE_SUBSCRIPTION_ID}/resourceGroups/${AZURE_RESOURCE_GROUP}/providers/Microsoft.KeyVault/vaults/${KEY_VAULT_NAME}"
        },
        "secretName": "AGENT-TOKEN-EXCHANGE-SECRET"
      }
    },
    "entraClientSecret": {
      "reference": {
        "keyVault": {
          "id": "/subscriptions/${AZURE_SUBSCRIPTION_ID}/resourceGroups/${AZURE_RESOURCE_GROUP}/providers/Microsoft.KeyVault/vaults/${KEY_VAULT_NAME}"
        },
        "secretName": "ENTRA-CLIENT-SECRET"
      }
    }
  }
}
